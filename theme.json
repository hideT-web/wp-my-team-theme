{
  "version": 3,
  "title": "My Team Theme",

  "settings": {
    "appearanceTools": true,

    "custom": {
      "base-font-size": "1.0625rem"
    },

    "color": {
      "palette": [
        { "color": "#0051ff", "name": "プライマリ", "slug": "primary" },
        { "color": "#6c757d", "name": "セカンダリ", "slug": "secondary" },
        { "color": "#ffffff", "name": "ベース", "slug": "base" },
        { "color": "#ede4d3", "name": "ベース補助", "slug": "base-alt" },
        { "color": "#0051ff", "name": "リンク", "slug": "link" },
        { "color": "#800000", "name": "リンク（hover）", "slug": "link-hover" },
        { "color": "#000000", "name": "文字色", "slug": "contrast" }
      ]
    },

    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },

    "spacing": {
      "customSpacingSize": true,
      "units": ["px", "em", "rem", "vh", "vw"]
    },

    "typography": {
      "lineHeight": true,
      "letterSpacing": true,
      "fontSizes": [
        { "slug": "xs", "size": "0.8rem", "name": "XS" },
        { "slug": "sm", "size": "0.9rem", "name": "S" },
        { "slug": "md", "size": "1.0625rem", "name": "M" },
        { "slug": "lg", "size": "1.25rem", "name": "L" },
        { "slug": "xl", "size": "1.8rem", "name": "XL" },
        { "slug": "xxl", "size": "2.4rem", "name": "XXL" }
      ]
    },

    "useRootPaddingAwareAlignments": true
  },

  "styles": {

    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },

    "typography": {
      "fontSize": "var(--wp--custom--base-font-size)",
      "lineHeight": "1.7",
      "letterSpacing": "0.02em"
    },

    "spacing": {
      "blockGap": "1.5rem"
    },

    "elements": {
      "h1": {
        "typography": {
          "fontSize": "clamp(2rem, 3vw, 2.4rem)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "clamp(1.6rem, 2.5vw, 1.8rem)",
          "fontWeight": "700",
          "lineHeight": "1.4"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--lg)"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--md)"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--md)",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--md)",
          "textTransform": "uppercase"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--link)"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--link-hover)"
          },
          "typography": {
            "textDecoration": "underline"
          }
        }
      }
    },

    "blocks": {
      "core/heading": {
        "typography": {
          "fontWeight": "700"
        }
      }
    }
  }
}